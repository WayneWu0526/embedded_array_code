<launch>
  <!-- Data Collection Task Launch File -->

  <!-- Arguments -->
  <arg name="mode" default="CVT"/>
  <arg name="manual_trigger" default="false"/>
  <arg name="sensor_type" default="QMC6309"/>
  <arg name="sensor_float_endian" default="little"/>

  <!-- ===================== -->
  <!-- 1. Vision System (localization_tagslam) -->
  <!-- ===================== -->
  <include file="$(find zlab_robots_calibration)/launch/localization_tagslam.launch"/>

  <!-- ===================== -->
  <!-- 2. Hall Sensor Serial Node (TDM Binary Protocol) -->
  <!-- ===================== -->
  <node name="serial_node_tdm" pkg="serial_processor" type="serial_node_tdm.py" output="screen">
    <param name="port" value="/dev/ttyACM"/>
    <param name="baudrate" value="921600"/>
    <param name="sensor_float_endian" value="$(arg sensor_float_endian)"/>
    <param name="sensor_type" value="$(arg sensor_type)"/>
  </node>

  <!-- ===================== -->
  <!-- 3. Signal Generator (FY8300) -->
  <!-- ===================== -->
  <!-- manual_trigger=true 时使用 manual 配置，否则根据 mode 选择 CVT/CCI 配置 -->
  <node name="fy8300" pkg="signal_generator" type="fy8300_node" output="screen">
    <rosparam if="$(eval arg('manual_trigger'))" command="load"
              file="$(find sensor_data_collection)/config/signal_params_manual.yaml"/>
    <rosparam if="$(eval not arg('manual_trigger') and arg('mode') == 'CVT')" command="load"
              file="$(find sensor_data_collection)/config/signal_params_cvt.yaml"/>
    <rosparam if="$(eval not arg('manual_trigger') and arg('mode') == 'CCI')" command="load"
              file="$(find sensor_data_collection)/config/signal_params_cci.yaml"/>
  </node>

  <!-- ===================== -->
  <!-- 4. Data Collection Node -->
  <!-- ===================== -->
  <node name="data_collection_node" pkg="sensor_data_collection"
        type="data_collection_node.py" output="screen">
    <!-- 模式无关的通用参数 -->
    <rosparam command="load" file="$(find sensor_data_collection)/config/task_params.yaml"/>

    <!-- 模式相关的采集参数 -->
    <rosparam if="$(eval mode == 'CVT')" command="load"
              file="$(find sensor_data_collection)/config/params_cvt.yaml"/>
    <rosparam if="$(eval mode == 'CCI')" command="load"
              file="$(find sensor_data_collection)/config/params_cci.yaml"/>

    <!-- 显式传递 launch 参数 -->
    <param name="mode" value="$(arg mode)"/>
    <param name="manual_trigger" value="$(arg manual_trigger)"/>
    <param name="sensor_type" value="$(arg sensor_type)"/>
  </node>

  <!-- ===================== -->
  <!-- 5. GELS Localization Service -->
  <!-- ===================== -->
  <include file="$(find gels_localization)/launch/localization_service.launch">
    <arg name="sensor_type" value="$(arg sensor_type)"/>
  </include>

</launch>
