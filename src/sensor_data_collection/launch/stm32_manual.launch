<launch>
  <!-- STM32 Manual Mode Launch File -->
  <!-- 仅启动STM32下位机，手动操作模式 -->

  <!-- Arguments -->
  <arg name="port" default="/dev/ttyACM"/>
  <arg name="baudrate" default="921600"/>
  <arg name="sensor_type" default="QMC6309"/>
  <arg name="sensor_float_endian" default="little"/>

  <!-- Hall Sensor Serial Node (TDM Binary Protocol) - Manual Mode -->
  <node name="serial_node_tdm" pkg="serial_processor" type="serial_node_tdm.py" output="screen">
    <param name="port" value="$(arg port)"/>
    <param name="baudrate" value="$(arg baudrate)"/>
    <param name="sensor_float_endian" value="$(arg sensor_float_endian)"/>
    <param name="sensor_type" value="$(arg sensor_type)"/>
    <!-- Manual record parameters -->
    <param name="output_dir" value="$(env HOME)/sensor_data_collection/data"/>
    <param name="frames_to_average" value="10"/>
  </node>

  <!-- Auto-send manual mode initialization command -->
  <node name="stm32_init" pkg="serial_processor" type="stm32_init.py" output="screen"/>

  <!-- ================================================ -->
  <!-- Manual Record Usage (手动记录使用方法)           -->
  <!-- ================================================ -->
  <!--
  主题触发方式:
    $ rostopic pub -1 /serial_node_tdm/record_trigger std_msgs/Bool "data: true"   # 开始/继续记录
    $ rostopic pub -1 /serial_node_tdm/record_trigger std_msgs/Bool "data: false"  # 暂停记录

  查看状态:
    $ rostopic echo /serial_node_tdm/stm_manual_record/status

  输出文件:
    ~/sensor_data_collection/data/manual_record_<timestamp>.csv
    - 37列: timestamp, sensor1_x, sensor1_y, sensor1_z, ..., sensor12_x, sensor12_y, sensor12_z
    - 每10帧平均为1行 (frames_to_average=10)
    - 单位: Gs, 6位小数
    - True后新建文件, False暂停(文件保持open), 再次True续写同一文件
  -->

</launch>
